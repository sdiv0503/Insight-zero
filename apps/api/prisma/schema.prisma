generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalysisReport {
  id           String   @id @default(uuid())
  dataSource   String
  summary      String?
  anomalyCount Int?
  rawJson      Json?
  createdAt    DateTime @default(now())
}